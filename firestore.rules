rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Catch-all Safeguard: Secure by default!
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Auth & Identity Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperUser() {
      return isSignedIn() && ('email' in request.auth.token) && request.auth.token.email in [
        "dwayne.edwards89@googlemail.com",
        "dwayne.edwards89@gmail.com",
        "natasha.penfold95@gmail.com"
      ];
    }
    
    function isEmailVerified() {
      return isSignedIn() && ((('email_verified' in request.auth.token) && request.auth.token.email_verified == true) || request.auth.uid != null || isSuperUser());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations (Pillars of Integrity)
    function isValidExercise(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.equipment is string && data.equipment.size() <= 100
        && (data.userId == request.auth.uid || isSuperUser());
    }

    function isValidWorkout(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.startTime is string && data.startTime.size() <= 100
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000))
        && data.exercises is list
        && (data.userId == request.auth.uid || isSuperUser());
    }

    function isValidTemplate(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.exercises is list
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000))
        && (data.userId == request.auth.uid || isSuperUser());
    }

    function isValidExerciseNote(data) {
      return (data.userId == request.auth.uid || isSuperUser())
        && data.exerciseId is string && data.exerciseId.size() <= 128
        && data.notes is string && data.notes.size() <= 5000;
    }

    function isValidUserSheets(data) {
      return !('spreadsheetId' in data) || data.spreadsheetId == null || (data.spreadsheetId is string && data.spreadsheetId.size() <= 128);
    }

    // Group 1: Custom Exercises rules
    match /custom_exercises/{exerciseId} {
      allow read, write: if isSuperUser();
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isSuperUser());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperUser());
      allow create: if isEmailVerified() && isValidId(exerciseId) && isValidExercise(incoming()) && incoming().id == exerciseId;
      allow update: if isEmailVerified() && isValidId(exerciseId) && isValidExercise(incoming()) && incoming().id == exerciseId && (incoming().userId == existing().userId || isSuperUser());
      allow delete: if isEmailVerified() && isValidId(exerciseId) && (existing().userId == request.auth.uid || isSuperUser());
    }

    // Group 2: Completed Workouts Log rules
    match /workouts/{workoutId} {
      allow read, write: if isSuperUser();
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isSuperUser());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperUser());
      allow create: if isEmailVerified() && isValidId(workoutId) && isValidWorkout(incoming()) && incoming().id == workoutId;
      allow update: if isEmailVerified() && isValidId(workoutId) && isValidWorkout(incoming()) && incoming().id == workoutId && (incoming().userId == existing().userId || isSuperUser());
      allow delete: if isEmailVerified() && isValidId(workoutId) && (existing().userId == request.auth.uid || isSuperUser());
    }

    // Group 3: Saved Templates rules
    match /templates/{templateId} {
      allow read, write: if isSuperUser();
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isSuperUser());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperUser());
      allow create: if isEmailVerified() && isValidId(templateId) && isValidTemplate(incoming()) && incoming().id == templateId;
      allow update: if isEmailVerified() && isValidId(templateId) && isValidTemplate(incoming()) && incoming().id == templateId && (incoming().userId == existing().userId || isSuperUser());
      allow delete: if isEmailVerified() && isValidId(templateId) && (existing().userId == request.auth.uid || isSuperUser());
    }

    // Group 4: Exercise Notes rules
    match /exercise_notes/{noteId} {
      allow read, write: if isSuperUser();
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isSuperUser());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperUser());
      allow create, update: if isEmailVerified() && isValidId(noteId) && isValidExerciseNote(incoming());
      allow delete: if isEmailVerified() && isValidId(noteId) && (existing().userId == request.auth.uid || isSuperUser());
    }

    // Group 5: Google Sheets Sync metadata rules
    match /user_sheets/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperUser());
      allow write: if request.auth != null && (request.auth.uid == userId || isSuperUser()) && isValidUserSheets(incoming());
    }

    match /your_new_collection/{documentId} {
      allow read: if request.auth.uid == resource.data.userId;
      // You would add create, update, and delete rules here as needed.
    }
  }
}

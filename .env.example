# GEMINI_API_KEY: Required for Gemini AI API calls. SERVER-SIDE ONLY.
# Never prefix this with VITE_ and never reference it from the React app — that
# would bundle it into the client where anyone can read it. Only server.ts reads
# it (process.env.GEMINI_API_KEY). Paste the real key into a local .env file
# (which is gitignored), and set it as a secret/env var on Cloud Run for deploy.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Which Gemini model the server uses. Optional — defaults to
# gemini-flash-lite-latest if unset. Swap here without touching code.
GEMINI_MODEL="gemini-flash-lite-latest"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Absolute base URL of the backend, for the CLIENT to call.
# This is NOT secret (it is just a URL) so the VITE_ prefix is fine here.
#  - Web build: leave EMPTY. The app and API share an origin, so relative paths
#    work and an absolute URL is unnecessary.
#  - Native (Capacitor) build: MUST be set to the deployed backend, e.g.
#    https://your-service-xxxx.run.app . A relative /api path inside the WebView
#    resolves to the bundled index.html and returns HTML, not JSON.
VITE_API_BASE_URL=""

# FIREBASE_PROJECT_ID: Optional. Used only to verify caller ID tokens. On Cloud
# Run, GOOGLE_CLOUD_PROJECT is injected automatically, so this is rarely needed;
# it falls back to the public project id in firebase-applet-config.json.
# FIREBASE_PROJECT_ID="gen-lang-client-0615336375"

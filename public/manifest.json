{
  "id": "/?homescreen=1",
  "name": "Project PB",
  "short_name": "Project PB",
  "description": "Voice-enabled intelligent athletic logger and Gemini Coach.",
  "lang": "en-US",
  "dir": "ltr",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "standalone",
    "window-controls-overlay",
    "tabbed",
    "minimal-ui"
  ],
  "background_color": "#04040a",
  "theme_color": "#04040a",
  "orientation": "portrait",
  "categories": [
    "fitness",
    "sports",
    "health",
    "lifestyle"
  ],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.projectpb.workouts",
      "id": "com.projectpb.workouts"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/projectpb-workouts/id123456789",
      "id": "com.projectpb.workouts"
    }
  ],
  "scope_extensions": [
    {
      "origin": "https://*.projectpb.io"
    },
    {
      "origin": "https://*.projectpb.app"
    }
  ],
  "iarc_rating_id": "76ec2a66-70eb-40bd-b65a-07204f1a26d2",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Project PB Performance Monitor on Desktop"
    },
    {
      "src": "/screenshot-mobile.png",
      "sizes": "720x1280",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Project PB Active Logger and Live Gemini Coach on Mobile"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Workout",
      "short_name": "Workout",
      "description": "Start a new workout session immediately",
      "url": "/?action=start_workout",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "View Analytics",
      "short_name": "Analytics",
      "description": "Visualize your performance indices",
      "url": "/?action=analytics",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Exercise Guide",
      "short_name": "Guide",
      "description": "Learn correct posture and exercises with Gemini Pro Coach",
      "url": "/?action=guide",
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "/?action=open_file",
      "accept": {
        "application/json": [".json"],
        "application/x-projectpb": [".projectpb"]
      },
      "icons": [
        {
          "src": "/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+projectpb",
      "url": "/?uri=%s"
    }
  ],
  "share_target": {
    "action": "/?action=share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "edge_side_panel": {
    "preferred_width": 400
  }
}
